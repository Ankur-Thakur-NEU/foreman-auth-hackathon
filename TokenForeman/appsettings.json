{
  "Auth0": {
    "Domain": "YOUR_TENANT.us.auth0.com",
    "ClientId": "YOUR_M2M_OR_SPA_CLIENT_ID",
    "ClientSecret": "YOUR_CLIENT_SECRET"
  },
  "Cors": {
    "AllowedOrigins": ""
  },
  "RateLimit": {
    "PerMinute": 60
  },
  "GoogleCalendar": {
    "CalendarId": "primary",
    "TimeZone": "UTC"
  },
  "Slack": {
    "BotToken": "xoxb-YOUR_SLACK_BOT_TOKEN",
    "DefaultChannel": "#general"
  },
  "Procore": {
    "ProjectId": "YOUR_PROCORE_PROJECT_ID",
    "CompanyId": "YOUR_PROCORE_COMPANY_ID"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "TokenForeman": "Information"
    }
  },
  "AllowedHosts": "*"
}
